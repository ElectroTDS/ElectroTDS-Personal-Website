<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Video Game Tracker</title>

<style>
body{
    font-family:Arial, sans-serif;
    margin:20px;
    background:#f5f5f5;
}

h1{
    margin-bottom:15px;
}

.filters{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
    gap:10px;
    margin-bottom:20px;
}

.filters input,
.filters select{
    padding:8px;
    width:100%;
}

.stats{
    display:flex;
    gap:25px;
    margin-bottom:15px;
    font-weight:bold;
    font-size:18px;
}

table{
    width:100%;
    border-collapse:collapse;
    background:white;
}

th,td{
    border:1px solid #ccc;
    padding:8px;
    text-align:left;
}

th{
    background:#333;
    color:white;
}

.progress-select{
    width:100%;
}

/* Row Colors */
.no-progress{
    background:#ffffff;
}

.in-progress{
    background:#cd7f32;
    color:white;
}

.beaten{
    background:#c0c0c0;
}

.completed{
    background:#ffd700;
}

.all-cheevos{
    background:#4da6ff;
    color:white;
}

.all-subsets{
    background:#9966cc;
    color:white;
}

.award{
    font-size:24px;
    text-align:center;
}
</style>
</head>
<body>

<h1>Video Game Collection Tracker</h1>

<div class="stats">
    <div>Rows Displayed: <span id="rowCount">0</span></div>
    <div>Completed: <span id="completedCount">0</span></div>
    <div>All Cheevos: <span id="cheevosCount">0</span></div>
</div>

<div class="filters">
    <input type="text" id="titleFilter" placeholder="Video Game Title">
    <input type="text" id="genreFilter" placeholder="Genre">
    <input type="text" id="franchiseFilter" placeholder="Franchise">
    <input type="text" id="consoleFilter" placeholder="Console">
    <input type="text" id="companyFilter" placeholder="Company">

    <select id="progressFilter">
        <option value="">All Progress</option>
        <option>No Progress</option>
        <option>In Progress</option>
        <option>Beaten</option>
        <option>Completed</option>
        <option>All Cheevos</option>
        <option>All Subsets</option>
    </select>

    <input type="text" id="rankFilter" placeholder="Rank">
</div>

<table id="gameTable">
<thead>
<tr>
    <th>Game Title</th>
    <th>Genre</th>
    <th>Franchise</th>
    <th>Console</th>
    <th>Company</th>
    <th>Progress</th>
    <th>Rank</th>
    <th>Award Icon</th>
    <th>Award Icon 2</th>
</tr>
</thead>
<tbody>

<tr>
    <td>Halo Infinite</td>
    <td>FPS</td>
    <td>Halo</td>
    <td>Xbox Series X</td>
    <td>Microsoft</td>
    <td>
        <select class="progress-select">
            <option>No Progress</option>
            <option selected>Completed</option>
            <option>In Progress</option>
            <option>Beaten</option>
            <option>All Cheevos</option>
            <option>All Subsets</option>
        </select>
    </td>
    <td>1</td>
    <td class="award1"></td>
    <td class="award2"></td>
</tr>

<tr>
    <td>The Witcher 3</td>
    <td>RPG</td>
    <td>The Witcher</td>
    <td>PC</td>
    <td>CD Projekt</td>
    <td>
        <select class="progress-select">
            <option>No Progress</option>
            <option>Completed</option>
            <option>In Progress</option>
            <option>Beaten</option>
            <option selected>All Cheevos</option>
            <option>All Subsets</option>
        </select>
    </td>
    <td>2</td>
    <td class="award1"></td>
    <td class="award2"></td>
</tr>

<tr>
    <td>Mario Kart 8 Deluxe</td>
    <td>Racing</td>
    <td>Mario Kart</td>
    <td>Switch</td>
    <td>Nintendo</td>
    <td>
        <select class="progress-select">
            <option selected>No Progress</option>
            <option>Completed</option>
            <option>In Progress</option>
            <option>Beaten</option>
            <option>All Cheevos</option>
            <option>All Subsets</option>
        </select>
    </td>
    <td>3</td>
    <td class="award1"></td>
    <td class="award2"></td>
</tr>

</tbody>
</table>

<script>

function updateRow(row){

    const progress = row.querySelector('.progress-select').value;

    row.className = '';

    const award1 = row.querySelector('.award1');
    const award2 = row.querySelector('.award2');

    award1.innerHTML = '';
    award2.innerHTML = '';

    switch(progress){

        case "No Progress":
            row.classList.add("no-progress");
            break;

        case "In Progress":
            row.classList.add("in-progress");
            break;

        case "Beaten":
            row.classList.add("beaten");
            break;

        case "Completed":
            row.classList.add("completed");
            award1.innerHTML = "🏆";
            break;

        case "All Cheevos":
            row.classList.add("all-cheevos");
            award1.innerHTML = "🏆";
            award2.innerHTML = "💎";
            break;

        case "All Subsets":
            row.classList.add("all-subsets");
            award1.innerHTML = "🏆";
            award2.innerHTML = "🔮";
            break;
    }
}

function updateCounters(){

    let completed = 0;
    let cheevos = 0;

    document.querySelectorAll("#gameTable tbody tr").forEach(row=>{

        const progress = row.querySelector(".progress-select").value;

        if(progress === "Completed"){
            completed++;
        }

        if(progress === "All Cheevos"){
            cheevos++;
        }
    });

    document.getElementById("completedCount").textContent = completed;
    document.getElementById("cheevosCount").textContent = cheevos;
}

function filterTable(){

    const title = document.getElementById("titleFilter").value.toLowerCase();
    const genre = document.getElementById("genreFilter").value.toLowerCase();
    const franchise = document.getElementById("franchiseFilter").value.toLowerCase();
    const consoleF = document.getElementById("consoleFilter").value.toLowerCase();
    const company = document.getElementById("companyFilter").value.toLowerCase();
    const progress = document.getElementById("progressFilter").value;
    const rank = document.getElementById("rankFilter").value.toLowerCase();

    let visibleRows = 0;

    document.querySelectorAll("#gameTable tbody tr").forEach(row=>{

        const cells = row.cells;

        const show =
            cells[0].textContent.toLowerCase().includes(title) &&
            cells[1].textContent.toLowerCase().includes(genre) &&
            cells[2].textContent.toLowerCase().includes(franchise) &&
            cells[3].textContent.toLowerCase().includes(consoleF) &&
            cells[4].textContent.toLowerCase().includes(company) &&
            cells[6].textContent.toLowerCase().includes(rank) &&
            (progress === "" ||
             row.querySelector(".progress-select").value === progress);

        row.style.display = show ? "" : "none";

        if(show){
            visibleRows++;
        }
    });

    document.getElementById("rowCount").textContent = visibleRows;
}

document.querySelectorAll(".progress-select").forEach(select=>{

    updateRow(select.closest("tr"));

    select.addEventListener("change", ()=>{

        updateRow(select.closest("tr"));
        updateCounters();
        filterTable();
    });
});

document.querySelectorAll(".filters input, .filters select")
.forEach(el=>{
    el.addEventListener("input", filterTable);
    el.addEventListener("change", filterTable);
});

updateCounters();
filterTable();

</script>

</body>
</html>